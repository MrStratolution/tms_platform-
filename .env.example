# PostgreSQL — Drizzle `tma_custom` (postgresql:// or postgres://)
# Bundled DB (after `npm run db:up`): host port 5443. One server only (e.g. postgres-site on :5432):
# DATABASE_URL=postgresql://tma:tma@127.0.0.1:5432/tma_platform_4069
DATABASE_URL=postgresql://tma:tma@127.0.0.1:5443/tma_platform_4069
POSTGRES_USER=tma
POSTGRES_PASSWORD=tma
POSTGRES_DB=tma_platform_4069
COMPOSE_PROJECT_NAME=tma-platform-4069

# Custom admin at /console (JWT cookie). Generate a long random string (≥32 chars).
# ADMIN_SESSION_SECRET=

# Console sign-in rate limit (per IP; same sliding window helper as forms when Upstash unset)
# CONSOLE_LOGIN_RATE_LIMIT_MAX=20
# CONSOLE_LOGIN_RATE_LIMIT_WINDOW_MS=900000

# Public URL (no trailing slash). MUST match the browser (scheme + host + port).
# This repo defaults dev to port 4069 (`npm run dev`). For port 3000 use `npm run dev:3000` and set URL to http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:4069

# Server timezone for built-in booking slots (e.g. Europe/Berlin)
# TZ=Europe/Berlin

# Optional: internal notifications (comma-separated). Uses Resend when RESEND_API_KEY is set.
INTERNAL_NOTIFY_EMAILS=

# SMTP password encryption for /console/email-system (falls back to ADMIN_SESSION_SECRET when unset)
# SMTP_ENCRYPTION_KEY=

# Resend (https://resend.com) — required for outbound mail from the app
# RESEND_API_KEY=re_CQb8aQ1q_EFwwwFZDRJSANNypoU455NFM
# RESEND_FROM_EMAIL=TMA <web@the-modesty-argument.de>

# Form + booking confirm rate limit (defaults 30 / 15 min per IP)
# FORM_RATE_LIMIT_MAX=30
# FORM_RATE_LIMIT_WINDOW_MS=900000

# Optional: Upstash Redis for distributed rate limits (multi-instance / serverless)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Cloudflare Turnstile (optional bot protection)
# TURNSTILE_SECRET_KEY=
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# hCaptcha alternative to Turnstile
# HCAPTCHA_SECRET_KEY=

# Internal worker / integration calls
INTERNAL_API_SECRET=

# AI chat (OpenAI-compatible POST /v1/chat/completions) — copy generation + page translation jobs
# Prefer TMA_AI_*; OPENAI_* still works for backward compatibility.
# TMA_AI_API_KEY=sk-...your-key...
# TMA_AI_BASE_URL=https://api.openai.com/v1
# TMA_AI_MODEL=gpt-4o-mini
# Local LM Studio example: TMA_AI_BASE_URL=http://127.0.0.1:1234/v1  TMA_AI_MODEL=meta-llama-3.1-8b-instruct
# OPENAI_API_KEY=sk-...your-key...
# OPENAI_MODEL=gpt-4o-mini
# Quick check: npm run smoke:ai

# Set to 1 to allow POST /api/ab/assign (weighted bucket + HttpOnly cookie) from the browser
# NEXT_PUBLIC_AB_ASSIGN_API=0

# Draft JSON preview + in-console responsive preview: /preview/[slug]?secret=...
# Generate locally: npm run ensure-preview-secret
# INTERNAL_PREVIEW_SECRET=

# Feature flag for WordPress-like hybrid page builder UI in /console/pages/[id]
# Set to 1 to enable new shell, contextual section settings, templates, and local history/autosave.
# NEXT_PUBLIC_BUILDER_V2=0

# Zoho CRM — OAuth refresh (see Zoho API console)
# ZOHO_CLIENT_ID=
# ZOHO_CLIENT_SECRET=
# ZOHO_REFRESH_TOKEN=
# ZOHO_ACCOUNTS_DOMAIN=https://accounts.zoho.com
# ZOHO_API_DOMAIN=https://www.zohoapis.com

# After each new lead, POST sync in background (requires INTERNAL_API_SECRET + public URL)
# ZOHO_AUTO_SYNC=true

# Dev: treat sync as successful without calling Zoho
# ZOHO_USE_MOCK=true

# Optional: force Zoho sync to record a failed CRM log (for testing)
# ZOHO_SYNC_MOCK_FAILURE=true

# Optional: Calendly webhook signing key
# CALENDLY_WEBHOOK_SIGNING_KEY=
